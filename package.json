{
  "name": "volunteer-connect",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter @vc/web",
    "dev:api": "turbo dev --filter @vc/api",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "check": "prettier --write \"**/*.{ts,tsx,json,md}\" && turbo lint typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky",
    "verify:deploy": "node scripts/verify-deploy.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0"
  },
  "packageManager": "pnpm@10.17.1",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write",
    "apps/web/**/*.{ts,tsx}": "pnpm --filter @vc/web exec eslint --fix",
    "apps/api/**/*.ts": "pnpm --filter @vc/api exec eslint --fix",
    "packages/db/**/*.ts": "pnpm --filter @vc/db exec eslint --fix",
    "packages/types/**/*.ts": "pnpm --filter @vc/types exec eslint --fix",
    "packages/zod/**/*.ts": "pnpm --filter @vc/zod exec eslint --fix"
  }
}
